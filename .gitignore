.gradle
/local.properties
/.idea
.DS_Store
/build
/captures
.externalNativeBuild
.cxx
local.properties
app/release/
*.jks
*.keystore
# …except the fixed debug keystore (non-secret android/android creds): committing
# it gives every debug build one stable signature → in-place updates, no uninstall,
# Ubuntu rootfs preserved. See app/build.gradle signingConfigs.debug.
!app/debug.keystore

# nodejs-mobile native libraries (downloaded by CI / scripts/download-libnode.sh)
app/src/main/jniLibs/arm64-v8a/libnode.so
app/src/main/jniLibs/armeabi-v7a/libnode.so
node_modules/
package.json
package-lock.json

# Local dev notes — not for the repo. Public README.md and
# .github/ISSUE_TEMPLATE/*.md are kept tracked via the !-rules below.
*.md
!README.md
!.github/ISSUE_TEMPLATE/*.md
