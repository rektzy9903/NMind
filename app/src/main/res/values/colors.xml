<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ── Nexus dark-frosted glassmorphism (2026-06-12) ──────────────────────
         XML counterpart to UiCommon.kt. Pure-black base + colourless white-
         translucent glass surfaces; accents = amber / cyan / rose / emerald
         (no purple). Drives the terminal header/toolbar AND the Settings views. -->

    <!-- ── Background layers ── -->
    <color name="bg_dark">#000000</color>
    <color name="surface">#0BFFFFFF</color>        <!-- rgba(255,255,255,0.045) frosted card fill -->
    <color name="surface2">#14FFFFFF</color>       <!-- ~8% white — elevated surface -->
    <color name="toolbar_bg">#000000</color>
    <color name="terminal_bg">#000000</color>
    <!-- Translucent glass bars (header + session-tab strip) so the aurora_bg behind
         glows through instead of reading as flat black. ~72% black keeps header
         text legible over the aurora. -->
    <color name="glass_bar">#B8000000</color>
    <color name="glass_bar_2">#99000000</color>

    <!-- ── Borders ── -->
    <color name="border">#17FFFFFF</color>         <!-- rgba(255,255,255,0.09) glass edge -->
    <color name="border2">#2EFFFFFF</color>        <!-- ~18% white — stronger edge -->

    <!-- ── Text ── -->
    <color name="text_primary">#E6FFFFFF</color>   <!-- white .9 -->
    <color name="text_secondary">#73FFFFFF</color> <!-- white .45 -->
    <color name="text_tertiary">#4DFFFFFF</color>  <!-- white .30 -->

    <!-- ── Amber accent (primary / Chat) ── -->
    <color name="accent_orange">#FF8C42</color>
    <color name="accent_orange_dark">#E5612A</color>
    <color name="accent_orange_dim">#FF8C4222</color>

    <!-- ── Emerald (success / free / Testing) ── -->
    <color name="accent_green">#10FFAB</color>
    <color name="accent_green_dim">#10FFAB14</color>

    <!-- ── Cyan (info / Quick Ask) ── -->
    <color name="accent_blue">#00D4FF</color>

    <!-- ── Amber (warning) ── -->
    <color name="accent_amber">#FBBF24</color>

    <!-- ── Status ── -->
    <color name="error_red">#FF4D6D</color>        <!-- rose -->
    <color name="warning_bg">#0A0A0D</color>
    <color name="warning_text">#FF8C42</color>

    <!-- ── Tab / indicator ── -->
    <color name="tab_active">#FF8C42</color>
</resources>
