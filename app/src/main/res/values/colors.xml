<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ── Background layers ── -->
    <!-- Glass reskin: surface/surface2/border are translucent white so XML cards
         read as glass; dark base layers stay opaque.
         (Originals: surface #151518, surface2 #1E1E22, border #2A2A30, border2 #3A3A42.) -->
    <color name="bg_dark">#0C0C0F</color>
    <color name="surface">#14FFFFFF</color>
    <color name="surface2">#1FFFFFFF</color>
    <color name="toolbar_bg">#0C0C0F</color>
    <color name="terminal_bg">#0C0C0F</color>

    <!-- ── Borders ── -->
    <color name="border">#24FFFFFF</color>
    <color name="border2">#33FFFFFF</color>

    <!-- ── Text ── -->
    <color name="text_primary">#F0F0F2</color>
    <color name="text_secondary">#9090A0</color>
    <color name="text_tertiary">#60606E</color>

    <!-- ── Amber accent (primary) ── -->
    <color name="accent_orange">#E8834A</color>
    <color name="accent_orange_dark">#C4632A</color>
    <color name="accent_orange_dim">#E8834A22</color>

    <!-- ── Green (success / free) ── -->
    <color name="accent_green">#3DD68C</color>
    <color name="accent_green_dim">#3DD68C18</color>

    <!-- ── Blue (local / info) ── -->
    <color name="accent_blue">#60A5FA</color>

    <!-- ── Amber (warning) ── -->
    <color name="accent_amber">#FBBF24</color>

    <!-- ── Status ── -->
    <color name="error_red">#F87171</color>
    <color name="warning_bg">#1A120A</color>
    <color name="warning_text">#E8834A</color>

    <!-- ── Tab / indicator ── -->
    <color name="tab_active">#E8834A</color>
</resources>
