<?xml version="1.0" encoding="utf-8"?>
<!--
  Convergence Gate — dark-frosted glass theme (2026-06-13).
  108×108dp adaptive icon foreground. Safe zone = 66dp circle (33dp radius from center 54,54).

  Four palette "paths" (cyan / rose / amber / emerald — no purple) converge from
  the cardinal edges through the diamond tips into a single amber core — the
  tagline "many paths · one door" made literal. The diamond "door" is frosted
  white so the coloured paths read against it. Mirrors the Compose ConvergenceLogo
  + SplashAnimationScreen. Cardinal/tip order: top, right, bottom, left.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Frosted glass pane behind the gate: diagonal white sheen -->
    <path android:pathData="M54,27 L81,54 L54,81 L27,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="30" android:startY="30"
                android:endX="78" android:endY="78"
                android:startColor="#2EFFFFFF"
                android:centerColor="#12FFFFFF"
                android:endColor="#0AFFFFFF" />
        </aapt:attr>
    </path>

    <!-- Top-left edge highlight (glass catches the light) -->
    <path android:pathData="M54,27 L27,54"
        android:strokeColor="#4DFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Diagonal accent lines from inner corners to center — faint white -->
    <path android:pathData="M18,18 L54,54"
        android:strokeColor="#24FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M90,18 L54,54"
        android:strokeColor="#24FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M18,90 L54,54"
        android:strokeColor="#24FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M90,90 L54,54"
        android:strokeColor="#24FFFFFF"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Cardinal "paths" through the diamond tips to center — one hue each -->
    <path android:pathData="M54,9 L54,54"
        android:strokeColor="#8C00D4FF"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M99,54 L54,54"
        android:strokeColor="#8CFF4D6D"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M54,99 L54,54"
        android:strokeColor="#8CFF8C42"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M9,54 L54,54"
        android:strokeColor="#8C10FFAB"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Diamond "door" outline — frosted white -->
    <path android:pathData="M54,27 L81,54 L54,81 L27,54 Z"
        android:strokeColor="#9EFFFFFF"
        android:strokeWidth="3.0"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- Tip dots at diamond vertices — one hue each (r=3.6) -->
    <path android:pathData="M54,27 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#D900D4FF"/>
    <path android:pathData="M81,54 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#D9FF4D6D"/>
    <path android:pathData="M54,81 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#D9FF8C42"/>
    <path android:pathData="M27,54 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#D910FFAB"/>

    <!-- Center glow halo — amber core (r=9) -->
    <path android:pathData="M54,54 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0"
        android:fillColor="#26FF8C42"/>

    <!-- Center node solid — the "one door" (r=5.4) -->
    <path android:pathData="M54,54 m-5.4,0 a5.4,5.4 0 1,0 10.8,0 a5.4,5.4 0 1,0 -10.8,0"
        android:fillColor="#FF8C42"/>

</vector>
