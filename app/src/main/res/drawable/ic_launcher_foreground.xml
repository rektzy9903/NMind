<?xml version="1.0" encoding="utf-8"?>
<!--
  Convergence Gate — Option A (Converging Lines)
  108×108dp adaptive icon foreground. Safe zone = 66dp circle (33dp radius from center 54,54).

  Scaled 1:1 from HTML nexus-mind-logo.html Option A (60dp viewBox → 108dp, factor 1.8×):
    Diamond tips at 27dp from center (54±27): top(54,27) right(81,54) bottom(54,81) left(27,54)
    Cardinal lines from near-edge (y=9/x=9) through tips to center — strokeWidth 3.0
    Diagonal lines from inner corners (18,18) etc. to center — strokeWidth 2.5
    Diamond strokeWidth 3.0, opacity 0.60
    Tip dots r=3.6 (opacity 0.50)
    Center glow r=9 (opacity 0.15), center node r=5.4 solid
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Frosted glass pane behind the gate: diagonal white sheen → warm tint -->
    <path android:pathData="M54,27 L81,54 L54,81 L27,54 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="30" android:startY="30"
                android:endX="78" android:endY="78"
                android:startColor="#2EFFFFFF"
                android:centerColor="#12FFFFFF"
                android:endColor="#0AE8834A" />
        </aapt:attr>
    </path>

    <!-- Top-left edge highlight (glass catches the light) -->
    <path android:pathData="M54,27 L27,54"
        android:strokeColor="#4DFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Diagonal accent lines from inner corners to center (0.20 opacity = #33) -->
    <path android:pathData="M18,18 L54,54"
        android:strokeColor="#33E8834A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M90,18 L54,54"
        android:strokeColor="#33E8834A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M18,90 L54,54"
        android:strokeColor="#33E8834A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M90,90 L54,54"
        android:strokeColor="#33E8834A"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Cardinal lines from near-edge through diamond tips to center (0.35 opacity = #59) -->
    <path android:pathData="M54,9 L54,54"
        android:strokeColor="#59E8834A"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M99,54 L54,54"
        android:strokeColor="#59E8834A"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M54,99 L54,54"
        android:strokeColor="#59E8834A"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M9,54 L54,54"
        android:strokeColor="#59E8834A"
        android:strokeWidth="3.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Diamond outline — tips at 27dp from center (0.60 opacity = #99) -->
    <path android:pathData="M54,27 L81,54 L54,81 L27,54 Z"
        android:strokeColor="#99E8834A"
        android:strokeWidth="3.0"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- Tip dots at diamond vertices (0.50 opacity = #80, r=3.6) -->
    <path android:pathData="M54,27 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#80E8834A"/>
    <path android:pathData="M81,54 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#80E8834A"/>
    <path android:pathData="M54,81 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#80E8834A"/>
    <path android:pathData="M27,54 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#80E8834A"/>

    <!-- Center glow halo (0.15 opacity = #26, r=9) -->
    <path android:pathData="M54,54 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0"
        android:fillColor="#26E8834A"/>

    <!-- Center node solid (r=5.4) -->
    <path android:pathData="M54,54 m-5.4,0 a5.4,5.4 0 1,0 10.8,0 a5.4,5.4 0 1,0 -10.8,0"
        android:fillColor="#E8834A"/>

</vector>
