<?xml version="1.0" encoding="utf-8"?>
<!--
  Convergence Gate — small header size (28dp rendered)
  24×24 viewBox, simplified from Option A 36px HTML spec:
  no diagonal lines, no tip dots — just diamond + cardinal lines + center node.
  Matches the inline SVG avatar used in index.html chat bubbles.
  Glass reskin: the diamond gets a frosted translucent-white gradient pane behind
  the amber outline (brighter top-left → faint warm bottom-right) so it reads as a
  glass tile to match the glassed header bar. Amber outline + glowing core stay on top.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Frosted glass pane (behind everything): diagonal white sheen → warm tint -->
    <path android:pathData="M12,2 L22,12 L12,22 L2,12 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="4" android:startY="4"
                android:endX="20" android:endY="20"
                android:startColor="#2EFFFFFF"
                android:centerColor="#14FFFFFF"
                android:endColor="#0AE8834A" />
        </aapt:attr>
    </path>

    <!-- Top-left edge highlight (glass catches the light) -->
    <path android:pathData="M12,2 L2,12"
        android:strokeColor="#4DFFFFFF"
        android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Cardinal lines from near-edge through tips to center (opacity 0.40) -->
    <path android:pathData="M12,1 L12,12"
        android:strokeColor="#66E8834A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M23,12 L12,12"
        android:strokeColor="#66E8834A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M12,23 L12,12"
        android:strokeColor="#66E8834A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
    <path android:pathData="M1,12 L12,12"
        android:strokeColor="#66E8834A"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Diamond outline — tips at ~10dp from center (opacity 0.65) -->
    <path android:pathData="M12,2 L22,12 L12,22 L2,12 Z"
        android:strokeColor="#A6E8834A"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- Center glow (opacity 0.18, r=4) -->
    <path android:pathData="M12,12 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0"
        android:fillColor="#2EE8834A"/>

    <!-- Center node solid (r=2.4) -->
    <path android:pathData="M12,12 m-2.4,0 a2.4,2.4 0 1,0 4.8,0 a2.4,2.4 0 1,0 -4.8,0"
        android:fillColor="#E8834A"/>

</vector>
