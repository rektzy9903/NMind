<?xml version="1.0" encoding="utf-8"?>
<!-- Container for the native Ubuntu-overlay mode toggle (mirrors the WebView
     #mode-toggle): frosted dark pill + hairline glass edge. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_bar_2" />
    <corners android:radius="9dp" />
    <stroke android:width="1dp" android:color="@color/border" />
</shape>
