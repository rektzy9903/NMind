<?xml version="1.0" encoding="utf-8"?>
<!-- Static color-rich aurora for native (XML) screens, matching the Compose
     AuroraBackground. Pure-black base + four soft radial blobs in
     cyan / amber / rose / emerald (no purple). Cards over this read as
     frosted glass. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/bg_dark" />
    <item android:gravity="fill">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.12" android:centerY="0.08"
                android:gradientRadius="520dp"
                android:startColor="#3300D4FF"
                android:endColor="#0000D4FF" />
        </shape>
    </item>
    <item android:gravity="fill">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.92" android:centerY="0.12"
                android:gradientRadius="460dp"
                android:startColor="#30FF8C42"
                android:endColor="#00FF8C42" />
        </shape>
    </item>
    <item android:gravity="fill">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.86" android:centerY="0.92"
                android:gradientRadius="560dp"
                android:startColor="#30FF4D6D"
                android:endColor="#00FF4D6D" />
        </shape>
    </item>
    <item android:gravity="fill">
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:centerX="0.08" android:centerY="0.96"
                android:gradientRadius="460dp"
                android:startColor="#2C10FFAB"
                android:endColor="#0010FFAB" />
        </shape>
    </item>
</layer-list>
