<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg"
    android:fitsSystemWindows="true">

    <!-- ── Header bar ───────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/toolbar_bg"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="4dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_terminal"
            android:tint="@color/accent_blue"
            android:contentDescription="Claude Code" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingStart="10dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Settings"
            android:padding="10dp" />

    </LinearLayout>

    <!-- ── Session tab strip ─────────────────────────────────────────────── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@color/bg_dark"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/tabContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="5dp">

            <!-- Session tabs added programmatically before this "+" button -->
            <Button
                android:id="@+id/btnNewSession"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="34dp"
                android:layout_height="30dp"
                android:text="+"
                android:textSize="16sp"
                android:textColor="@color/accent_blue"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Connecting indicator ───────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connecting to Claude bridge…"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:background="@color/surface"
        android:visibility="visible" />

    <!-- ── Terminal WebView — takes all remaining space ───────────────────── -->
    <WebView
        android:id="@+id/webViewTerminal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/terminal_bg"
        android:scrollbars="none" />

    <!-- ── Restart button (shown when active session exits) ──────────────── -->
    <Button
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Restart Claude Code"
        android:backgroundTint="@color/accent_orange"
        android:visibility="gone"
        android:layout_margin="8dp" />

    <!-- ── Message status bar (thinking / timeout / error) ───────────────── -->
    <LinearLayout
        android:id="@+id/llStatus"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:background="@color/surface"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressThinking"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminateTint="@color/accent_orange" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:text="Thinking…" />

        <Button
            android:id="@+id/btnRetryMessage"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Retry"
            android:textColor="@color/accent_orange"
            android:textSize="12sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="0dp"
            android:visibility="gone" />

    </LinearLayout>


</LinearLayout>
