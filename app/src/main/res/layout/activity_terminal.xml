<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg"
    android:fitsSystemWindows="true">

    <!-- ── Header bar ───────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/toolbar_bg"
        android:gravity="center_vertical"
        android:minHeight="52dp"
        android:paddingStart="14dp"
        android:paddingEnd="4dp"
        android:paddingVertical="6dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Claude Code" />

        <!-- App name + model pill stacked vertically -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvModelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="claude"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="visible"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="2dp"
                android:paddingHorizontal="4dp" />

            <TextView
                android:id="@+id/tvProjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text=""
                android:textColor="#8010B981"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="start"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="2dp"
                android:paddingHorizontal="4dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnTts"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🔇"
            android:textSize="16sp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            android:paddingVertical="0dp"
            android:contentDescription="Toggle TTS" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Settings"
            android:padding="10dp" />

    </LinearLayout>

    <!-- ── Session tab strip ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_dark">

        <!-- Thin top divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- "SESSIONS" label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"
                android:text="SESSIONS"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:fontFamily="monospace" />

            <!-- Scrollable tab buttons -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/tabContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="4dp">

                    <!-- Session tabs added programmatically before this "+" button -->
                </LinearLayout>
            </HorizontalScrollView>

            <!-- "+ New Session" button, always visible -->
            <Button
                android:id="@+id/btnNewSession"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="＋ New"
                android:textSize="11sp"
                android:textColor="@color/accent_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginEnd="6dp" />

        </LinearLayout>

        <!-- Thin bottom divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface" />

    </LinearLayout>

    <!-- ── Connecting indicator ───────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connecting to Claude bridge…"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:background="@color/surface"
        android:visibility="visible" />

    <!-- ── Terminal WebView — takes all remaining space ───────────────────── -->
    <WebView
        android:id="@+id/webViewTerminal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/terminal_bg"
        android:scrollbars="none" />

    <!-- ── Restart button (shown when active session exits) ──────────────── -->
    <Button
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Restart Claude Code"
        android:backgroundTint="@color/accent_orange"
        android:visibility="gone"
        android:layout_margin="8dp" />

    <!-- ── Message status bar (thinking / timeout / error) ───────────────── -->
    <LinearLayout
        android:id="@+id/llStatus"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:background="@color/surface"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressThinking"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminateTint="@color/accent_orange" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:text="Thinking…" />

        <Button
            android:id="@+id/btnRetryMessage"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Retry"
            android:textColor="@color/accent_orange"
            android:textSize="12sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="0dp"
            android:visibility="gone" />

    </LinearLayout>


</LinearLayout>
