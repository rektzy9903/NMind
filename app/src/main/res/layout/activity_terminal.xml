<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/aurora_bg"
    android:fitsSystemWindows="true">

    <!-- ── Header bar ───────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/glass_bar"
        android:gravity="center_vertical"
        android:minHeight="52dp"
        android:paddingStart="14dp"
        android:paddingEnd="4dp"
        android:paddingVertical="6dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_logo_small"
            android:contentDescription="Nexus Mind" />

        <!-- App name + model pill stacked vertically -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvModelName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="claude"
                android:textColor="@color/accent_blue"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="visible"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="2dp"
                android:paddingHorizontal="4dp" />

            <TextView
                android:id="@+id/tvProjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text=""
                android:textColor="#8010B981"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="start"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="2dp"
                android:paddingHorizontal="4dp" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnTts"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_volume_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle TTS"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Settings"
            android:padding="10dp" />

    </LinearLayout>

    <!-- ── Session tab strip ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/glass_bar_2">

        <!-- Thin top divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- "SESSIONS" label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="4dp"
                android:text="SESSIONS"
                android:textColor="@color/text_secondary"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:fontFamily="monospace" />

            <!-- Scrollable tab buttons -->
            <HorizontalScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:id="@+id/tabContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="4dp">

                    <!-- Session tabs added programmatically before this "+" button -->
                </LinearLayout>
            </HorizontalScrollView>

            <!-- "+ New Session" button, always visible -->
            <Button
                android:id="@+id/btnNewSession"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="＋ New"
                android:textSize="11sp"
                android:textColor="@color/accent_blue"
                android:paddingHorizontal="10dp"
                android:paddingVertical="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:layout_marginEnd="6dp" />

        </LinearLayout>

        <!-- Thin bottom divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface" />

    </LinearLayout>

    <!-- ── Connecting indicator ───────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connecting to Claude bridge…"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingVertical="6dp"
        android:background="@color/surface"
        android:visibility="visible" />

    <!-- ── Terminal content area (WebView + optional native overlay) ───────── -->
    <FrameLayout
        android:id="@+id/terminalContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Chat (always) + Ubuntu xterm (WebView-renderer mode) -->
        <WebView
            android:id="@+id/webViewTerminal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/terminal_bg"
            android:scrollbars="none" />

        <!-- Native 🐧 Ubuntu renderer (Termux terminal-view). Opaque, covers the
             WebView while in Ubuntu mode; GONE otherwise. The TerminalView is added
             into nativeTermHost programmatically. Only used when the native-terminal
             pref is on — else this whole overlay stays GONE. -->
        <LinearLayout
            android:id="@+id/nativeUbuntuOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/terminal_bg"
            android:visibility="gone">

            <FrameLayout
                android:id="@+id/nativeTermHost"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Native key row (the in-WebView toolbar is covered while native is up) -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/glass_bar_2"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="3dp">

                    <Button android:id="@+id/btnNativeChat" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="‹ Chat" android:textSize="12sp" android:textColor="@color/accent_blue"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeEsc" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="Esc" android:textSize="12sp" android:textColor="@color/text_primary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeTab" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="Tab" android:textSize="12sp" android:textColor="@color/text_primary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeCtrlC" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="^C" android:textSize="12sp" android:textColor="@color/accent_orange"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeUp" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="↑" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeDown" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="↓" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeLeft" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="←" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeRight" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="→" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeFontDec" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="A−" android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                    <Button android:id="@+id/btnNativeFontInc" style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content" android:layout_height="34dp"
                        android:text="A+" android:textSize="12sp" android:textColor="@color/text_secondary"
                        android:minWidth="0dp" android:minHeight="0dp" android:paddingHorizontal="10dp" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- ── Restart button (shown when active session exits) ──────────────── -->
    <Button
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Restart Claude Code"
        android:backgroundTint="@color/accent_orange"
        android:visibility="gone"
        android:layout_margin="8dp" />

    <!-- ── Message status bar (thinking / timeout / error) ───────────────── -->
    <LinearLayout
        android:id="@+id/llStatus"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="6dp"
        android:background="@color/surface"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressThinking"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminateTint="@color/accent_orange" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:text="Thinking…" />

        <Button
            android:id="@+id/btnRetryMessage"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="Retry"
            android:textColor="@color/accent_orange"
            android:textSize="12sp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="0dp"
            android:visibility="gone" />

    </LinearLayout>


</LinearLayout>
