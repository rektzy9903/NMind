<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbar_bg"
        app:title="Settings"
        app:titleTextColor="@color/text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Current provider section -->
            <TextView
                style="@style/SectionHeader"
                android:text="Current Setup" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Provider / Model"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCurrentProvider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="start">

                    <Button
                        android:id="@+id/btnChangeProvider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Change provider"
                        android:backgroundTint="@color/accent_green" />

                    <Button
                        android:id="@+id/btnChangeModel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change model"
                        android:backgroundTint="@color/accent_blue"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Versions -->
            <TextView
                style="@style/SectionHeader"
                android:text="Versions" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvClaudeVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAppVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Projects -->
            <TextView
                style="@style/SectionHeader"
                android:text="Projects" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create and switch between saved project workspaces. Each project has its own folder, system prompt, and persistent history."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnManageProjects"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manage Projects"
                    android:textColor="@color/accent_blue" />

            </LinearLayout>

            <!-- Tool permissions -->
            <TextView
                style="@style/SectionHeader"
                android:text="Tool Permissions" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pre-approve tools so Claude never asks for permission during a session."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnManageApprovals"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tool Permissions"
                    android:textColor="@color/accent_blue" />

            </LinearLayout>

            <!-- MCP Servers -->
            <TextView
                style="@style/SectionHeader"
                android:text="MCP Servers" />

            <LinearLayout
                android:id="@+id/mcpCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <!-- Populated dynamically in onResume() -->
                <LinearLayout
                    android:id="@+id/mcpServerRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <Button
                    android:id="@+id/btnMcpServers"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Manage MCP Servers"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- Scheduled prompts -->
            <TextView
                style="@style/SectionHeader"
                android:text="Scheduled Prompts" />

            <Button
                android:id="@+id/btnScheduledPrompts"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Manage scheduled prompts"
                android:textColor="@color/accent_blue" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Send prompts to Claude automatically at set times each day (e.g. daily standup, morning briefing)."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Custom slash commands -->
            <TextView
                style="@style/SectionHeader"
                android:text="Custom Commands" />

            <Button
                android:id="@+id/btnCustomCommands"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Manage custom slash commands"
                android:textColor="@color/accent_blue" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Commands appear as /command-name in claude. Each command is a markdown file in ~/.claude/commands/."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Live provider updates -->
            <TextView
                style="@style/SectionHeader"
                android:text="Live Provider Updates" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Provider update URL (leave empty to use bundled list)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProviderRemoteUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:textColor="@color/text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Point to a JSON file matching the providers.json format to push new providers/models without an app update."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Data management -->
            <TextView
                style="@style/SectionHeader"
                android:text="Data" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnClearData"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Clear saved API key &amp; settings"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reset and reinstall everything"
                    android:backgroundTint="@color/error_red" />

            </LinearLayout>

            <!-- Support -->
            <TextView
                style="@style/SectionHeader"
                android:text="Support" />

            <Button
                android:id="@+id/btnReport"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Report a problem (GitHub Issues)"
                android:textColor="@color/accent_blue" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
