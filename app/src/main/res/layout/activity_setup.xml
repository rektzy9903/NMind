<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="24dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Setup" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Set Up Nexus Mind"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Claude Code will be downloaded and installed inside the app.\nThis only happens once (~50 MB)."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:gravity="center" />

        <!-- ── Initial state ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutInitial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What will happen:"
                    android:textColor="@color/accent_orange"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Tap the button below\n2. Claude Code downloads automatically (~50 MB)\n3. No other apps needed — everything runs inside this app\n4. This screen advances automatically when done"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <Button
                android:id="@+id/btnStartSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Install Claude Code"
                android:textSize="16sp"
                android:backgroundTint="@color/accent_orange" />

        </LinearLayout>

        <!-- ── Waiting / installing state ──────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutWaiting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:visibility="gone">

            <!-- Current step label -->
            <TextView
                android:id="@+id/tvCurrentStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Starting..."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/progressSetup"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent_orange"
                android:progressBackgroundTint="@color/surface" />

            <!-- Install log -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:text="INSTALL LOG"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <ScrollView
                android:id="@+id/scrollTaskLog"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_provider_card"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvTaskLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.5" />

            </ScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Keep the app open. This page advances automatically when done."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:gravity="center" />

        </LinearLayout>

        <!-- ── Success state ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="@color/accent_orange"
                android:textSize="64sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Setup complete!"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Claude Code is ready. Now choose your AI provider."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:gravity="center" />

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Choose Provider →"
                android:textSize="16sp"
                android:backgroundTint="@color/accent_orange" />

        </LinearLayout>

        <!-- ── Error state ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_error_card"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvErrorMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/error_red"
                android:textSize="14sp" />

            <!-- Log in error state so user can see what failed -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="4dp"
                android:text="ERROR LOG"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <ScrollView
                android:id="@+id/scrollErrorLog"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_provider_card"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvErrorLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.5" />

            </ScrollView>

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnCopyLog"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Copy Log"
                    android:backgroundTint="@color/surface" />

                <Button
                    android:id="@+id/btnRetry"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Try Again"
                    android:backgroundTint="@color/accent_orange" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
