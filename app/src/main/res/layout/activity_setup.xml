<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="24dp"
            android:src="@drawable/ic_terminal"
            android:contentDescription="Setup" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Set Up Claude Code"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="We'll install Claude Code inside Ubuntu Linux via Termux.\nThis only happens once (5–15 minutes)."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.4"
            android:gravity="center" />

        <!-- ── Initial state ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutInitial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_provider_card"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What will happen:"
                    android:textColor="@color/accent_orange"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Termux will open and run the setup\n2. Ubuntu Linux is installed (~300 MB)\n3. Node.js and Claude Code are installed\n4. A local proxy is installed (free mode)\n5. When done, tap back and this screen advances automatically"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <Button
                android:id="@+id/btnStartSetup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Setup in Termux"
                android:textSize="16sp"
                android:backgroundTint="@color/accent_orange" />

        </LinearLayout>

        <!-- ── Waiting state ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutWaiting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:visibility="gone">

            <!-- Current step label -->
            <TextView
                android:id="@+id/tvCurrentStep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connecting to Termux..."
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Horizontal determinate progress bar -->
            <ProgressBar
                android:id="@+id/progressSetup"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent_orange"
                android:progressBackgroundTint="@color/surface" />

            <!-- Task log header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="4dp"
                android:text="SETUP LOG"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <!-- Scrollable real-time task log -->
            <ScrollView
                android:id="@+id/scrollTaskLog"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_provider_card"
                android:scrollbars="vertical">

                <TextView
                    android:id="@+id/tvTaskLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.5" />
            </ScrollView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="This page advances automatically when setup completes (usually 5–15 min)."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:gravity="center" />

            <!-- Manual fallback card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_provider_card"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="IF NOTHING HAPPENS IN TERMUX:"
                    android:textColor="@color/accent_orange"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Open Termux manually\n2. Copy and run this command:"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvManualCmd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_provider_card"
                    android:padding="10dp"
                    android:text="proot-distro install ubuntu &amp;&amp; proot-distro login ubuntu"
                    android:fontFamily="monospace"
                    android:textColor="@color/accent_orange"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnCopyCmd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Copy command"
                    android:textSize="13sp"
                    android:backgroundTint="@color/accent_orange" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Success state ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="@color/accent_orange"
                android:textSize="64sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Setup complete!"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Claude Code is ready. Now choose your AI provider."
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:gravity="center" />

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Choose Provider →"
                android:textSize="16sp"
                android:backgroundTint="@color/accent_orange" />

        </LinearLayout>

        <!-- ── Error state ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_error_card"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvErrorMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/error_red"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Try again"
                android:backgroundTint="@color/accent_orange" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
