<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:name=".ClaudeApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NexusMind"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:extractNativeLibs="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Splash / Entry -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share text into Claude Code -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- First-time setup (npm install progress) -->
        <activity
            android:name=".SetupActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Main terminal -->
        <activity
            android:name=".TerminalActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.NexusMind.Terminal" />

        <!-- Provider / login selection (Compose) -->
        <activity
            android:name=".ui.ComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.NexusMind" />

        <!-- Home screen (main menu) -->
        <activity
            android:name=".ui.HomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Model response tester -->
        <activity
            android:name=".ui.ModelTestActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Token Usage dashboard -->
        <activity
            android:name=".ui.UsageActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Settings -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Project Manager -->
        <activity
            android:name=".ui.ProjectManagerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- MCP Server Manager -->
        <activity
            android:name=".ui.McpActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.NexusMind" />

        <!-- Discussion (multi-model debate) -->
        <activity
            android:name=".ui.DiscussionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.NexusMind" />

        <!-- Quick Ask (native multi-provider chat) -->
        <activity
            android:name=".ui.QuickAskActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.NexusMind" />

        <activity
            android:name=".ui.DungeonActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Web Preview -->
        <activity
            android:name=".ui.PreviewActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.NexusMind" />

        <!-- Claude.ai OAuth WebView login -->
        <activity
            android:name=".ui.ClaudeLoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.NexusMind" />

        <!-- Foreground service: keeps bridge sessions alive -->
        <service
            android:name=".services.ClaudeService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Boot receiver -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
